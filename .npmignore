# 不发到 npm 的内容
#
# 注：package.json 没设 `files` 字段；npm 用本文件作 deny-list。
# 真正应该 ship 的是 dist/ + src/defaults + src/runtime + README + CHANGELOG。
# 以下排除规则覆盖 default + 把不该发的源码挡掉。

# 测试
**/__tests__/
*.test.ts
*.test.tsx
*.test.js
*.test.mjs
vitest.config.ts

# 内部源码（公开 raw export 只用 src/defaults + src/runtime；其余不需要发）
src/__tests__/
src/adapters/
src/app/
src/cache/
src/cli/
src/config/
src/context/
src/discovery/
src/engine/
src/index.ts
src/isr/
src/logger/
src/manifest/
src/metrics/
src/middlewares/
src/plugin/
src/renderer/
src/route/
src/rsc/
src/server/
src/ssg/
src/types/
src/utils/

# 构建 / 工具配置
vite.config.ts
tsconfig.json
tsconfig.build.json
src/defaults/tsconfig.json
eslint.config.mjs
.eslintcache
.prettierrc
.prettierignore
.editorconfig
.nvmrc
.npmrc.example
.vscode/

# CI / 仓库元
.github/
.gitignore
.npmrc

# 开发产物
.vite/
.cache/
.tmp/
.temp/
.isr-cache/
**/.isr-hyou/
*.tsbuildinfo

# Bench / examples（不随 npm 包发）
bench/
examples/
docs/

# 日志
logs/
*.log

# OS
.DS_Store
Thumbs.db
