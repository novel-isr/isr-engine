{
  "name": "@novel-isr/engine",
  "version": "2.3.0",
  "description": "ISR/SSG/Fallback rendering orchestration on Vite + React 19 RSC.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/novel-isr/isr-engine.git"
  },
  "homepage": "https://github.com/novel-isr/isr-engine",
  "bugs": "https://github.com/novel-isr/isr-engine/issues",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/novel-isr.cjs",
  "module": "./dist/novel-isr.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "novel-isr": "./dist/cli/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/novel-isr.js",
      "require": "./dist/novel-isr.cjs",
      "types": "./dist/index.d.ts"
    },
    "./rsc": {
      "import": "./dist/rsc/index.js",
      "require": "./dist/rsc/index.cjs",
      "types": "./dist/rsc/index.d.ts"
    },
    "./server-entry": {
      "default": "./src/defaults/runtime/defineServerEntry.tsx"
    },
    "./client-entry": {
      "default": "./src/defaults/runtime/defineClientEntry.tsx"
    },
    "./auto-observability": {
      "types": "./dist/defaults/auto-observability.d.ts",
      "default": "./src/defaults/auto-observability.ts"
    },
    "./site-hooks": {
      "types": "./dist/defaults/runtime/defineSiteHooks.d.ts",
      "default": "./src/defaults/runtime/defineSiteHooks.ts"
    },
    "./adapters/observability": {
      "import": "./dist/adapters/observability/index.js",
      "require": "./dist/adapters/observability/index.cjs",
      "types": "./dist/adapters/observability/index.d.ts"
    },
    "./adapters/runtime": {
      "import": "./dist/adapters/runtime/index.js",
      "require": "./dist/adapters/runtime/index.cjs",
      "types": "./dist/adapters/runtime/index.d.ts"
    },
    "./image": {
      "import": "./dist/image/index.js",
      "require": "./dist/image/index.cjs",
      "types": "./dist/runtime/Image.d.ts"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./src/runtime/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && chmod +x dist/cli/cli.js dist/cli/cli.cjs",
    "watch": "vite build --watch",
    "clean": "rimraf dist",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "bench": "node bench/runner.mjs",
    "check": "pnpm run type-check && pnpm run lint && pnpm run test",
    "release": "pnpm run check && pnpm run build && pnpm publish --access restricted --no-git-checks",
    "prepare": "pnpm run build"
  },
  "engines": {
    "node": ">=22.21.1"
  },
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "@vitejs/plugin-rsc": "^0.5.24",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "compression": "^1.7.4",
    "esbuild": "^0.28.0",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "lru-cache": "^10.4.3",
    "ora": "^8.1.0",
    "prom-client": "^15.1.3",
    "sitemap": "^8.0.0",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-server-dom-webpack": "^19.0.0",
    "rsc-html-stream": "^0.0.7",
    "vite": "^8.0.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.1",
    "sharp": "^0.33.5"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@<0.1.13": "0.1.13"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/ioredis-mock": "^8.2.5",
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitest/coverage-v8": "^2.1.5",
    "autocannon": "^7.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.9.0",
    "ioredis-mock": "^8.9.0",
    "prettier": "^3.3.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-server-dom-webpack": "^19.2.0",
    "rimraf": "^6.0.1",
    "rsc-html-stream": "^0.0.7",
    "tsc-alias": "^1.8.16",
    "vite": "^8.0.0",
    "vitest": "^2.1.5"
  }
}
