{
  "name": "@novel-isr/engine",
  "version": "1.0.0",
  "description": "企业级服务端渲染引擎 - 自动降级链 ISR → SSR → CSR",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "novel-isr": "./dist/cli/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js",
    "./config": "./dist/config/index.js",
    "./engines": "./dist/engines/index.js",
    "./modules": "./dist/modules/index.js",
    "./utils": "./dist/utils/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "QUICK-START.md",
    "ISR-ARCHITECTURE.md",
    "ssr.config.example.js",
    "ssr.config.example.ts",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "ssr",
    "isr",
    "ssg",
    "react",
    "server-side-rendering",
    "incremental-static-regeneration",
    "static-site-generation",
    "enterprise",
    "fallback-chain"
  ],
  "author": "Novel Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.21.0",
    "node-fetch": "^3.3.2",
    "p-limit": "^6.1.0",
    "sitemap": "^8.0.0",
    "vite": "^5.4.8",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/node-fetch": "^2.6.11",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vite-plugin-dts": "^4.2.3",
    "vite-plugin-node": "^3.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/novel-team/isr-engine.git"
  },
  "homepage": "https://github.com/novel-team/isr-engine#readme",
  "bugs": {
    "url": "https://github.com/novel-team/isr-engine/issues"
  }
}
