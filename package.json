{
  "name": "@novel-isr/engine",
  "version": "2.2.0",
  "description": "构建于 @vitejs/plugin-rsc 之上的通用 ISR/SSG/Fallback 渲染编排框架。设计为跨项目复用：任何 Vite + React 19 + RSC 站点都可以接，不绑定特定业务。仅在私有 git/registry 发布，不发 public.",
  "private": false,
  "license": "UNLICENSED",
  "author": "internal",
  "keywords": [
    "isr",
    "ssg",
    "ssr",
    "rsc",
    "react-server-components",
    "vite",
    "framework",
    "rendering"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TaitaiWx/isr-engine.git"
  },
  "homepage": "https://github.com/TaitaiWx/isr-engine",
  "bugs": {
    "url": "https://github.com/TaitaiWx/isr-engine/issues"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "${NPM_REGISTRY_URL}"
  },
  "//-internal-only": "本包仅在内部私有 npm registry 发布。release.yml 在发布前会检查 NPM_REGISTRY_URL 是否指向内部 host；若为空或指向 registry.npmjs.org 则 fail-fast，杜绝误发 public。",
  "type": "module",
  "main": "./dist/novel-isr.cjs",
  "module": "./dist/novel-isr.js",
  "types": "./dist/novel-isr.d.ts",
  "typesVersions": {
    "*": {
      "virtual-modules": [
        "./src/types/virtual-modules.d.ts"
      ]
    }
  },
  "bin": {
    "novel-isr": "./dist/cli/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/novel-isr.js",
      "require": "./dist/novel-isr.cjs",
      "types": "./dist/novel-isr.d.ts"
    },
    "./rsc": {
      "import": "./dist/rsc/index.js",
      "require": "./dist/rsc/index.cjs",
      "types": "./dist/rsc/index.d.ts"
    },
    "./server-entry": {
      "default": "./src/defaults/runtime/defineServerEntry.tsx"
    },
    "./client-entry": {
      "default": "./src/defaults/runtime/defineClientEntry.tsx"
    },
    "./virtual-modules": {
      "types": "./dist/types/virtual-modules.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/cli.js",
      "require": "./dist/cli/cli.cjs"
    },
    "./adapters/observability": {
      "import": "./dist/adapters/observability/index.js",
      "require": "./dist/adapters/observability/index.cjs",
      "types": "./dist/adapters/observability/index.d.ts"
    },
    "./adapters/runtime": {
      "import": "./dist/adapters/runtime/index.js",
      "require": "./dist/adapters/runtime/index.cjs",
      "types": "./dist/adapters/runtime/index.d.ts"
    },
    "./image": {
      "import": "./dist/image/index.js",
      "require": "./dist/image/index.cjs",
      "types": "./dist/image/index.d.ts"
    },
    "./runtime": {
      "default": "./src/runtime/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/defaults",
    "src/adapters",
    "src/cache",
    "src/engine",
    "src/logger",
    "src/metrics",
    "src/plugin",
    "src/rsc",
    "src/runtime",
    "src/types",
    "src/middlewares",
    "src/context",
    "README.md",
    "ssr.config.example.ts"
  ],
  "scripts": {
    "build": "vite build && chmod +x dist/cli/cli.js dist/cli/cli.cjs",
    "watch": "vite build --watch",
    "clean": "rimraf dist",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "node scripts/bench.mjs",
    "bench:compare": "node scripts/bench-compare.mjs",
    "check": "pnpm run type-check && pnpm run lint && pnpm run format:check && pnpm run test",
    "release:dry": "pnpm run build && pnpm publish --dry-run --access restricted --no-git-checks",
    "release:pack": "pnpm run build && pnpm pack",
    "release": "pnpm run check && pnpm run build && pnpm publish --access restricted --no-git-checks",
    "release:from-ci": "pnpm publish --access restricted --no-git-checks",
    "prepublishOnly": "node -e \"const u=process.env.NPM_REGISTRY_URL||'';if(!u){console.error('NPM_REGISTRY_URL not set; this package is internal-only.');process.exit(1)}if(/registry\\.npmjs\\.org/.test(u)){console.error('NPM_REGISTRY_URL points to public npmjs; refusing to publish internal package.');process.exit(1)}\""
  },
  "engines": {
    "node": "22.21.1"
  },
  "dependencies": {
    "@vitejs/plugin-rsc": "^0.5.24",
    "commander": "^12.1.0",
    "compression": "^1.7.4",
    "esbuild": "^0.28.0",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "lru-cache": "^10.4.3",
    "ora": "^8.1.0",
    "prom-client": "^15.1.3",
    "react-server-dom-webpack": "^19.2.0",
    "rsc-html-stream": "^0.0.7",
    "sitemap": "^8.0.0",
    "typescript": "^5.6.2",
    "vite": "^8.0.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.1",
    "sharp": "^0.33.5"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@<0.1.13": "0.1.13"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/compression": "^1.7.5",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/express": "^4.17.21",
    "@types/ioredis-mock": "^8.2.5",
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitest/coverage-v8": "^2.1.5",
    "autocannon": "^7.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.9.0",
    "ioredis-mock": "^8.9.0",
    "prettier": "^3.3.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.5"
  }
}
