{
  "name": "@novel-isr/engine",
  "version": "1.0.0",
  "description": "企业级服务端渲染引擎 - 自动降级链 ISR → SSR → CSR",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "novel-isr": "./dist/cli/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js",
    "./config": "./dist/config/index.js",
    "./engines": "./dist/engines/index.js",
    "./modules": "./dist/modules/index.js",
    "./utils": "./dist/utils/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "QUICK-START.md",
    "ISR-ARCHITECTURE.md",
    "ssr.config.example.js",
    "ssr.config.example.ts",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "clean": "rimraf dist",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint && npm run format:check"
  },
  "keywords": [
    "ssr",
    "isr",
    "ssg",
    "react",
    "server-side-rendering",
    "incremental-static-regeneration",
    "static-site-generation",
    "enterprise",
    "fallback-chain"
  ],
  "author": "Novel Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "commander": "^12.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "esbuild": "^0.25.9",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "inquirer": "^10.2.2",
    "ioredis": "^5.4.1",
    "lru-cache": "^10.4.3",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.0",
    "p-limit": "^6.1.0",
    "rate-limiter-flexible": "^5.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "redis": "^5.9.0",
    "sitemap": "^8.0.0",
    "vite": "^5.4.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/eslint": "^9.6.1",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/node-fetch": "^2.6.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-node": "^3.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/novel-team/isr-engine.git"
  },
  "homepage": "https://github.com/novel-team/isr-engine#readme",
  "bugs": {
    "url": "https://github.com/novel-team/isr-engine/issues"
  }
}
